    "@types/node": "^22.14.0",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.1",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.19",
