{
  "name": "clix-hub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node api/index.js",
    "kill-port": "for /f \"tokens=5\" %a in ('netstat -aon ^| findstr :4000') do taskkill /f /pid %a",
    "electron-dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron-build": "vite build && electron-builder",
    "mobile:build": "vite build && npx cap sync",
    "mobile:android": "npx cap open android",
    "mobile:ios": "npx cap open ios"
  },
  "dependencies": {
    "@clerk/react": "^6.1.0",
    "@google/genai": "^1.39.0",
    "@supabase/supabase-js": "^2.104.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "framer-motion": "^12.38.0",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.563.0",
    "mongodb": "^6.12.0",
    "mongoose": "^9.3.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.3",
